# Copy to server/.env for local development. Never commit real values.
# In production these are set in the Render dashboard (Environment).

# MongoDB Atlas connection string (mongodb+srv://...). Rotate any leaked credential first.
MONGO_URI=

# Clerk authentication (https://dashboard.clerk.com → API Keys)
CLERK_SECRET_KEY=sk_test_...

# Allowed browser origin for CORS in dev (the Vite dev server).
# In production the app is same-origin, so this can be left blank.
CLIENT_ORIGIN=http://localhost:5173

# production | development
NODE_ENV=development

# Email — no longer needed for auth (Clerk handles it). Kept for any custom
# transactional emails you may add later.
RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev

# Handwriting OCR (Google Cloud Vision API key). Optional: if unset, the
# "Extract text" feature is disabled and typed-text search still works.
GOOGLE_VISION_KEY=
